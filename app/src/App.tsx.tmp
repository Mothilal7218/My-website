                  <a 
                    href={`#${link.toLowerCase()}`} 
                    className="font-body text-white/70 hover:text-brand-accent transition-colors duration-200 text-sm"
                  >
                    {link}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          {/* Connect */}
          <div>
            <h4 className="font-display font-semibold mb-4">Connect</h4>
