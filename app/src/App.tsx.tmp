            >
              <Mail size={16} /> hello@mothilalshankar.com
            </a>
          </div>
        </div>

        {/* Bottom */}
        <div className="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p className="font-body text-white/50 text-sm">
            © {new Date().getFullYear()} Mothilal Shankar. All rights reserved.
          </p>
          <button
            onClick={scrollToTop}
            className="flex items-center gap-2 font-body text-white/70 hover:text-brand-accent transition-colors duration-200 text-sm group"
          >
            Back to top <ChevronUp size={16} className="transition-transform duration-300 group-hover:-translate-y-1" />
          </button>
        </div>
      </div>
    </footer>
  );
}

// Main App
function App() {
  return (
    <div className="min-h-screen bg-white">
