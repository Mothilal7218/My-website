              <a 
                href="#" 
                className="p-2 bg-white/10 rounded-full hover:bg-brand-accent transition-colors duration-300"
                aria-label="Instagram"
              >
                <Instagram size={18} />
              </a>
              <a 
                href="#" 
                className="p-2 bg-white/10 rounded-full hover:bg-brand-accent transition-colors duration-300"
                aria-label="Twitter"
              >
                <Twitter size={18} />
              </a>
              <a 
                href="https://www.amazon.in/Mothilal-Shankar/e/B0FLWD73CG"
                target="_blank"
                rel="noopener noreferrer"
                className="p-2 bg-white/10 rounded-full hover:bg-brand-accent transition-colors duration-300"
